# Local environment config — copy to `.env` (repo root) and fill in YOUR values.
#
#   cp .env.example .env
#
# `.env` is gitignored: these values are personal and must not be committed.
# The iOS signing vars below are loaded by apps/coach-game/ios/package.sh via
# dotenvx (brew install dotenvx/brew/dotenvx). See apps/coach-game/BUILD.md →
# "One-time setup: cert + provisioning profile".

# codesign identity. Find yours: security find-identity -v -p codesigning
GURUKUL_IOS_IDENTITY="Apple Development: YOUR NAME (TEAMID)"

# Target device for local debug installs. Optional — if unset, the script
# auto-picks the sole connected device. Set it only to disambiguate when more
# than one device is plugged in. Find yours: xcrun devicectl list devices
#GURUKUL_IOS_DEBUG_DEVICE="00000000-0000-0000-0000-000000000000"

# Path to your .mobileprovision. Optional — you may instead pass --profile
# <path> or drop the file at apps/coach-game/ios/profile.mobileprovision.
#GURUKUL_IOS_PROFILE="/absolute/path/to/your.mobileprovision"
