{
  "$schema": "../schema/world.schema.json",
  "nodes": [
    { "id": "src", "type": "SineSource", "params": { "freq": 440.0, "amplitude": 0.5 } },
    { "id": "mid", "type": "Passthrough" },
    { "id": "out", "type": "NullSink" }
  ],
  "connections": [
    { "from": "src.audio_out", "to": "mid.audio_in" },
    { "from": "mid.audio_out", "to": "out.audio_in" }
  ]
}
