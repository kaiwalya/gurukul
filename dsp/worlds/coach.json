{
  "$schema": "../schema/world.schema.json",
  "world_version": 1,
  "in_ports": [
    { "id": "mic" }
  ],
  "out_ports": [
    { "id": "pitch" },
    { "id": "confidence" },
    { "id": "onset" },
    { "id": "breath" },
    { "id": "vibrato_rate" },
    { "id": "vibrato_amplitude" },
    { "id": "vibrato_phase" }
  ],
  "nodes": [
    {
      "id": "pitch_yin",
      "type": "PitchYin",
      "params": {
        "window": 2048,
        "hop": 512,
        "fmin_hz": 70.0,
        "fmax_hz": 1000.0,
        "threshold": 0.15
      }
    },
    {
      "id": "onset_det",
      "type": "Onset"
    },
    {
      "id": "breath_det",
      "type": "Breath"
    },
    {
      "id": "vibrato_det",
      "type": "Vibrato",
      "params": { "analysis_hop": 600 }
    }
  ],
  "connections": [
    { "from": "mic",                "to": "pitch_yin.audio_in" },
    { "from": "mic",                "to": "onset_det.audio_in" },
    { "from": "mic",                "to": "breath_det.audio_in" },
    { "from": "pitch_yin.f0",       "to": "vibrato_det.f0" },
    { "from": "pitch_yin.f0",       "to": "pitch" },
    { "from": "pitch_yin.confidence", "to": "confidence" },
    { "from": "onset_det.onset",    "to": "onset" },
    { "from": "breath_det.breath",  "to": "breath" },
    { "from": "vibrato_det.rate",   "to": "vibrato_rate" },
    { "from": "vibrato_det.amplitude",  "to": "vibrato_amplitude" },
    { "from": "vibrato_det.phase",  "to": "vibrato_phase" }
  ]
}
